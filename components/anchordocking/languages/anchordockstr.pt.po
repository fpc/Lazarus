#: anchordockstr.adrshideheadercaptionsforsiteswithonlyonedockedcontrol
msgid "Hide header captions for sites with only one docked control, as that is already shown in the normal window title"
msgstr "Ocultar as legendas do cabeçalho em sítios com apenas um controlo ancorado, uma vez que estas já aparecem no título normal da janela"

#: anchordockstr.adrshighlightfocused
msgid "Highlight focused"
msgstr "Realçar focado"

#: anchordockstr.adrshighlightfocusedhint
msgid "Highlight header of focused docked control"
msgstr "Realçar o cabeçalho do controlo ancorado focado"

