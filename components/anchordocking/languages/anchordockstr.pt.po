msgstr "Âncora não encontrada: Nó=\"%s\" Âncoras[%s]=\"%s\""

#: anchordockstr.adrsanchortowrongsideofsplitternodeanchors
#, object-pascal-format
msgid "Anchor to wrong side of splitter: Node=\"%s\" Anchors[%s]=\"%s\""
msgstr "Ancorado ao lado errado do divisor: Nó=\"%s\" Âncoras[%s]=\"%s\""

#: anchordockstr.adrsapagemustnotbeanchorednodeparentparenttypeanchors
#, object-pascal-format
msgid "A page must not be anchored: Node=\"%s\" Parent=%s ParentType=%s Anchors[%s]=\"%s\""
msgstr "Uma página não deve ter uma âncora: Nó=\"%s\" Mãe=%s Tipo de mãe=%s Âncoras[%s]=\"%s\""

#: anchordockstr.adrsareyousuretodelete
msgid "Are you sure you want to delete the backup file?"
msgstr "Tem a certeza de que deseja eliminar a salvaguarda?"

#: anchordockstr.adrsareyousuretorestore
msgid "Are you sure you want to restore the window layout? This will overwrite the current layout settings."
msgstr "Deseja realmente restaurar a disposição da janela? Isto vai sobrescrever a disposição actual."

