#: anchordockstr.adrsafreesideofasplittermustnotbeanchorednodetypeancho
#, object-pascal-format
msgid "A free side of a splitter must not be anchored: Node=\"%s\" Type=%s Anchors[%s]=\"%s\""
msgstr "Um lado livre de um divisor não deve ser ancorado: Nó=\"%s\" Tipo=%s Âncoras[%s]=\"%s\""

#: anchordockstr.adrsallowdocksitestobeminimized
msgid "Allow dock sites to be minimized"
msgstr "Permitir que sítios ancorados sejam minimizados"

#: anchordockstr.adrsamountofpixelthemousehastodragbeforedragstarts
msgid "Amount of pixel the mouse has to drag before drag starts"
msgstr "Distância em pixels que o rato tem de percorrer antes de arrastar"

#: anchordockstr.adrsanchordockbackuprecovery
msgctxt "anchordockstr.adrsanchordockbackuprecovery"
msgid "Backup/Restore Anchordocking Layout"
msgstr "Gravar/Restaurar a disposição do Anchordocking"

#: anchordockstr.adrsanchordockbackuprecoverycaption
msgctxt "anchordockstr.adrsanchordockbackuprecoverycaption"
msgid "Backup/Restore Anchordocking Layout"
