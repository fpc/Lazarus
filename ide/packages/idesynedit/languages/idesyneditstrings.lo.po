#: idesyneditstrings.dlgaddhiattrcustom
#, object-pascal-format
msgid "Custom %d"
msgstr "ກຳນົດເອງ %d"

#: idesyneditstrings.dlgaddhiattrnestedbracket
#, object-pascal-format
msgid "Nested bracket %d"
msgstr "ວົງເລັບຊ້ອນກັນ %d"

#: idesyneditstrings.synffoldcomments
msgid "Fold comments"
msgstr "ພັບຄຳອະທິບາຍ (comments)"

#: idesyneditstrings.synffoldcommentsinselection
msgid "Fold comments in selection"
msgstr "ພັບຄຳອະທິບາຍໃນສ່ວນທີ່ເລືອກ"

#: idesyneditstrings.synffoldinactiveifdef
msgid "Fold inactive Ifdef"
msgstr "ພັບ Ifdef ທີ່ບໍ່ໄດ້ເຮັດວຽກ"

#: idesyneditstrings.synffoldinactiveifdefexcludemixedstate
msgid "Fold inactive Ifdef (exclude mixed state)"
msgstr "ພັບ Ifdef ທີ່ບໍ່ໄດ້ເຮັດວຽກ (ຍົກເວັ້ນສະຖານະປະສົມ)"

#: idesyneditstrings.synffoldinactiveifdefinselection
msgid "Fold inactive Ifdef in selection"
msgstr "ພັບ Ifdef ທີ່ບໍ່ໄດ້ເຮັດວຽກໃນສ່ວນທີ່ເລືອກ"

#: idesyneditstrings.synffoldinactiveifdefinselectionexcludemixedstate
msgid "Fold inactive Ifdef in selection (exclude mixed state)"
msgstr "ພັບ Ifdef ທີ່ບໍ່ໄດ້ເຮັດວຽກໃນສ່ວນທີ່ເລືອກ (ຍົກເວັ້ນສະຖານະປະສົມ)"

#: idesyneditstrings.synfhidecomments
msgid "Hide comments"
msgstr "ເຊື່ອງຄຳອະທິບາຍ"

#: idesyneditstrings.synfhidecommentsinselection
msgid "Hide comments in selection"
msgstr "ເຊື່ອງຄຳອະທິບາຍໃນສ່ວນທີ່ເລືອກ"

#: idesyneditstrings.synfunfoldactiveifdef
msgid "Unfold active Ifdef"
msgstr "ຄາຍ Ifdef ທີ່ເຮັດວຽກຢູ່ອອກ"

#: idesyneditstrings.synfunfoldactiveifdefinselection
msgid "Unfold active Ifdef in selection"
msgstr "ຄາຍ Ifdef ທີ່ເຮັດວຽກຢູ່ອອກໃນສ່ວນທີ່ເລືອກ"

#: idesyneditstrings.synfunfoldall
msgid "Unfold all"
msgstr "ຄາຍອອກທັງໝົດ"

#: idesyneditstrings.synfunfoldallifdef
msgid "Unfold all Ifdef"
msgstr "ຄາຍ Ifdef ທັງໝົດອອກ"

#: idesyneditstrings.synfunfoldallifdefinselection
msgid "Unfold all Ifdef in selection"
msgstr "ຄາຍ Ifdef ທັງໝົດອອກໃນສ່ວນທີ່ເລືອກ"

#: idesyneditstrings.synfunfoldallinselection
msgid "Unfold all in selection"
msgstr "ຄາຍທັງໝົດອອກໃນສ່ວນທີ່ເລືອກ"

#: idesyneditstrings.synfunfoldcomments
msgid "Unfold comments"
msgstr "ຄາຍຄຳອະທິບາຍອອກ"

#: idesyneditstrings.synfunfoldcommentsinselection
msgid "Unfold comments in selection"
msgstr "ຄາຍຄຳອະທິບາຍອອກໃນສ່ວນທີ່ເລືອກ"

#: idesyneditstrings.synfunfoldinactiveifdef
msgid "Unfold inactive Ifdef"
msgstr "ຄາຍ Ifdef ທີ່ບໍ່ໄດ້ເຮັດວຽກອອກ"

#: idesyneditstrings.synfunfoldinactiveifdefinselection
msgid "Unfold inactive Ifdef in selection"
msgstr "ຄາຍ Ifdef ທີ່ບໍ່ໄດ້ເຮັດວຽກອອກໃນສ່ວນທີ່ເລືອກ"

